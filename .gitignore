# Root gitignore for spaceshield_defence project

# Next.js frontend dependencies and build outputs
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/*.tsbuildinfo

# Laravel backend dependencies and environment
backend/vendor/
backend/.env
backend/bootstrap/cache/
backend/storage/*.key
backend/storage/framework/cache/data/
backend/storage/framework/sessions/
backend/storage/framework/testing/
backend/storage/framework/views/

# OS/IDE files
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Stale / Temporary files
code.html:Zone.Identifier
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env*.local
.env
